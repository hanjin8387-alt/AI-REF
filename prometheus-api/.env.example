# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Shared app token (must match mobile app config)
APP_TOKEN=replace_with_long_random_token
REQUIRE_APP_TOKEN=true
ENVIRONMENT=production

# CORS origins (comma separated, explicit list only)
CORS_ORIGINS=https://ai-ref-web-274026276907.asia-northeast3.run.app

# Optional allow-list when REQUIRE_APP_TOKEN=false
ALLOWED_DEVICE_IDS=

# Upload and cache tuning
MAX_UPLOAD_SIZE_MB=8
RECIPE_CACHE_TTL_MINUTES=30

# Firebase (Base64 encoded credentials JSON)
FIREBASE_CREDENTIALS=base64_encoded_firebase_credentials

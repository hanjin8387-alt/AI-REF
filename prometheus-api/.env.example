# Core
APP_NAME=PROMETHEUS API
DEBUG=true
ENVIRONMENT=development

# App identity (public identifiers, not secrets)
APP_IDS=prometheus-app,prometheus-web
ALLOW_LEGACY_APP_TOKEN=false
REQUIRE_APP_TOKEN=false

# Legacy compatibility token (optional, temporary migration bridge)
# Required only when ALLOW_LEGACY_APP_TOKEN=true
APP_TOKEN=

# Admin secret token (server-side secret)
ADMIN_TOKEN=change-this-admin-token

# CORS origins (comma separated, explicit list only)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Optional allow-list for device ids
ALLOWED_DEVICE_IDS=

# Device token policy
DEVICE_TOKEN_TTL_HOURS=720

# Gemini API
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Upload and cache tuning
MAX_UPLOAD_SIZE_MB=8
RECIPE_CACHE_TTL_MINUTES=30

# Cache
CACHE_BACKEND=auto
REDIS_URL=

# Optional integrations
DEFAULT_LANGUAGE=ko
OPEN_FOOD_FACTS_ENABLED=true
FIREBASE_CREDENTIALS=
